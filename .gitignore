# Local toolchain (optional bootstrap)
.tools/

# App under test (cloned locally — never committed)
app-under-test/

# Dependencies
node_modules/

# Cypress artifacts
cypress/screenshots/
cypress/videos/
cypress/downloads/

# Playwright artifacts
playwright-report/
playwright/test-results/
test-results/
playwright/.auth/

# Allure (root + framework reports)
allure-results/
allure-report/
cypress/allure-results/
cypress/allure-report/
cypress/reports/allure-results/
cypress/reports/allure-report/
playwright/reports/allure-results/
playwright/reports/allure-report/
migration/allure-report/
migration/metrics/metrics.json

# Environment & secrets — live JWTs never committed
.env
.env.*
!.env.example

# Auth / storage state (generated at runtime)
**/storageState.json
**/.auth/
**/auth-state.json
**/user.json

# OS & IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs & temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
tmp/

# Coverage
coverage/
.nyc_output/

# Baseline run artifacts (summaries are committed)
migration/baseline/*/runs/

# Mentorship notes — local study material only (not published with the repo)
docs/mentorship/
